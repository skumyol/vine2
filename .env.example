# Copy this file to .env and fill in your values.
# Docker Compose reads .env automatically via env_file directive.

# ==== Required API Keys ====
# OpenRouter for VLM reasoning (Qwen vision models)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SerpAPI (optional — only used when VINO_RETRIEVAL_BACKEND=serpapi)
SERPAPI_API_KEY=

# ==== Runtime Configuration (optional, sensible defaults) ====

# Retrieval backend: fixture | serpapi | playwright | hybrid
# Prod default (via docker-compose): playwright (calls playwright microservice)
# VINO_RETRIEVAL_BACKEND=playwright

# Analyzer mode: strict | lenient
# VINO_ANALYZER_MODE=strict

# Pipeline variant: voter | paddle_qwen
# VINO_PIPELINE_NAME=voter

# CORS (comma-separated list of allowed origins)
# VINO_CORS_ORIGINS=http://localhost:3042,http://127.0.0.1:3042

# ==== Optional Integrations ====
# PaddleOCR-VL cloud OCR
# PADDLEOCR_API_URL=https://your-paddleocr-endpoint.com
# PADDLEOCR_ACCESS_TOKEN=your-token

# ==== Docker-specific overrides ====
# Image registry for push
# REGISTRY=docker.io/yourusername
